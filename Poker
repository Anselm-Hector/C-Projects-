void RoundStart() {
    int active=PlayersActive(),a=0;//prolly its own functiin
    for (int i = 0; i < active; i++) {
        if (players[i].state.folded==1||players[i].state.out==1) continue;
        a++;
    }
    if(a==1) {//when only 1 player left gives chips to player
        for(int i=0; i<4; i++) {
            players[i].chips+=(players[i].state.folded==0)? bet.pot: 0;
            printf("Winner is Player %d\n", players[i].player_number);
        }
    }
    do {
        for(int j=0; j<4; j++) {
            for(int i=0; i<4; i++) {
                if(i==0) {
                    if(players[0].player_number==j) PlayerMove();
                }
                if(players[i].player_number==j) BetLogic(i);
            }
        }
    } while(EqualBets()!=1);
}

bool EqualBets() {
    int active=PlayersActive();
    for(int i=0; i<active; i++) {
        if(players[i].state.allin==1) continue;
        if(players[i].bets<bet.call) return false;
    }
    return true;
}

void RoundEnd() {
    int winninghand=0,winner=0;
    int active = PlayersActive();
    magicno=1;
    for (int i = 0; i < active; i++) {
        if (players[i].state.folded==1) continue;
        if(players[i].ranking>winninghand) {
            players[i].ranking=winninghand;
            players[i].player_number=winner;
        }
    }
}

