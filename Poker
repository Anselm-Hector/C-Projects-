void PoolEvaluation() {
    int active=PlayersActive();
    int flag=0;
    int cardstrength[2]= {0};
    int poolint[7]= {0},empty[7]= {0},straight_count=0;
    char pcopy[7][3]= {""},pcopytwo[7][3]= {""};

    for (int i = 0; i < active; i++) {
        if (players[i].state.folded==0||players[i].state.out==0) {
            flag++;
        }
    }
    if(flag==1) {//when only 1 player left gives chips to player
        for(int i=0; i<active; i++) {
            players[i].chips=(players[i].state.folded==0)? G_pot+players[i].chips : Holder();
            printf("Winner is Player %d\n", players[i].player_number);
        }
    }

    for (int k = 0; k < active; k++) {
        int holder=0;
        int freq[13] = {0};
        int freqtwo[13] = {0};
        int suit_count[4] = {0};

        strcpy(pool[0], players[k].hand[0]);
        strcpy(pool[1], players[k].hand[1]);
        for(int i=0; i<7; i++) {
            strcpy(pcopy[i],pool[i]);
        }
        //flop evaluation
        for(int i=0; i<7; i++) {
            if(pcopy[i][0]!='\0') {
                freq[cardstrength[i]]++;
                pcopy[i][0]='\0';
            }
            if(cardstrength[i]>cardstrength[holder]) {//checks highcard
                players[k].rank.kicker=1;//fix this ltr
                holder=i;
            }
        }
        strcpy(highcard,pool[holder]);

        for (int i = 0; i < 13; i++) {//checks pair trips twopair fullhouse and quad
            if (freq[i] == 2) players[k].rank.pair=1;
            if (freq[i] == 3) players[k].rank.trips=1;
            if (freq[i] == 4) players[k].rank.quads=1;
        }
        if(players[k].rank.pair==1||players[k].rank.trips==1) {
            for(int i=0; i<7; i++) {
                if(pcopy[i][0]!='\0') {
                    freqtwo[cardstrength[i]]++;
                    pcopy[i][0]='\0';
                }
            }
            for (int i = 0; i < 13; i++) {
                if (freqtwo[i] == 2) players[k].rank.twopair=1;
                if (freqtwo[i] == 3) players[k].rank.trips=1;
                if (freqtwo[i] == 4) players[k].rank.quads=1;
            }
            if(players[k].rank.trips==1&&players[k].rank.pair==1) {
                players[k].rank.fullhouse=1;
            }
        }
        for(int i=0; i<7; i++) {
            poolint[i]=CardStrength(pool[i][1]);
        }
        for(int s=14; s!=1; s--) {
            for(int i=0; i<7; i++) {
                if(poolint[i]!=s) {
                    continue;
                }
                for(int j=0; j<7; j++) {
                    if(empty[j]!=0) {
                        continue;
                    }
                    empty[j]=poolint[i];
                }
            }
        }

        for(int i=0; i<7; i++) {
            if(empty[i]-empty[i+1]!=1&&straight_count!=5) {
                straight_count=0;
                empty[i]=0;
            }
            straight_count++;
            if(straight_count>5) {
                empty[i+1]=0;
            }
        }
        if(straight_count>=5) {
            players[k].rank.straight=1;
        }

        for (int i = 0; i < 7; i++) {
            char s = pool[i][1];

            if (s == 'h') suit_count[0]++;
            else if (s == 'd') suit_count[1]++;
            else if (s == 'c') suit_count[2]++;
            else if (s == 's') suit_count[3]++;
        }
        for (int i = 0; i < 4; i++) {
            if (suit_count[i] == 5) {
                players[k].rank.flush=true;
            }
            if (suit_count[i] > 5) {
                //check highcard of flush
                players[k].rank.flush=true;
            }
        }
        if(players[k].rank.flush==1&&players[k].rank.straight==1) {
            players[k].rank.straightflush=1;
        }
        if(players[k].rank.straightflush==1&&players[k].info.highcard[0]=='A') {
            players[k].rank.royalstraight=1;
        }
        Ranking(k);
    }
}

int Ranking(int i) {
    if(players[i].rank.kicker==1)
        return players[i].ranking=1;
    if(players[i].rank.pair==1)
        return players[i].ranking=2;
    if(players[i].rank.twopair==1)
        return players[i].ranking=3;
    if(players[i].rank.trips==1)
        return players[i].ranking=4;
    if(players[i].rank.straight==1)
        return players[i].ranking=5;
    if(players[i].rank.flush==1)
        return players[i].ranking=6;
    if(players[i].rank.fullhouse==1)
        return players[i].ranking=7;
    if(players[i].rank.quads==1)
        return players[i].ranking=8;
    if(players[i].rank.straightflush==1)
        return players[i].ranking=9;
    if(players[i].rank.royalstraight==1)
        return players[i].ranking=10;
}

void HandEvaluation() {
    int active=PlayersActive();

    for(int i=0; i<active; i++) {
        int cardstrength[2];
        cardstrength[0] = CardStrength(players[i].hand[0][0]);
        cardstrength[1] = CardStrength(players[i].hand[1][0]);
        players[i].info.strength = 0;
        players[i].info.strength=cardstrength[0]+cardstrength[1];
        players[i].info.range=abs(cardstrength[0]-cardstrength[1]);//if =0then pair 1-12shows how far apart card 1 is from card 2
        players[i].rank.pair=(cardstrength[0]==cardstrength[1]) ? 1 : 0;

        strcpy(players[i].info.highcard,players[i].hand[1]);
        players[i].rank.kicker=1;
        if(cardstrength[0]>cardstrength[1]) {
            strcpy(players[i].info.highcard,players[i].hand[0]);
            players[i].rank.kicker=1;
        } //checks highcard
        players[i].info.suited=0;
        if(players[i].hand[1][1]==players[i].hand[0][1]) {
            players[i].info.suited=1;
        }//checks for same suite
    }

    for(int i=0; i<active; i++) {
        printf("\nStrenght:%d pair:%d Highcard:%s suited:%d ",
               players[i].info.strength,players[i].rank.pair,players[i].info.highcard,
               players[i].info.suited);
    }
// printf("player1 highcard %s",players[0].info.highcard);
}

