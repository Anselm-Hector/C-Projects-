void Que() {
//Happens once on game start
    int active=PlayersActive();
    char playerque[4][4]= {"UTG","BTN","SB","BB"};
    int que=rand()%active;
    if(active!=4) {
        printf("Failure at Initialization");
        return;
    }
    for(int i=0; i<active; i++) {
        strlcpy(players[i].que,playerque[(i+que)%active],sizeof(players[i].que));
    }
    for(int i=0; i<active; i++) {
        for(int j=0; j<4; j++) {
            if(strcmp(players[i].que,playerque[j])!=0) continue;
            players[i].player_number=j;
        }
    }
}

//CRITICAL LOGIC
int PlayersActive() {
    int active=4;
    for(int i=0; i<4; i++) {
        if(players[i].chips==0||players[i].lives==0) {
            active--;
            players[i].state.out = true;
            players[i].state.active = false;
        }
    }
    if(active==1) {
        GameOverCheck();
    }
    return active;
}

void PoolEvaluation() {
    int active=PlayersActive();
    int cardstrength[2]= {0};
    int poolint[7]= {0},empty[7]= {0},straight_count=0;
    char pcopy[7][3]= {""},pcopytwo[7][3]= {""};

    for (int k = 0; k < active; k++) {
        int holder=0;
        int freq[13] = {0};
        int freqtwo[13] = {0};
        int suit_count[4] = {0};

        strlcpy(pool[0], players[k].hand[0],sizeof(pool[0]));
        strlcpy(pool[1], players[k].hand[1],sizeof(pool[1]));
        for(int i=0; i<7; i++) {//creating a copy of pool
            strlcpy(pcopy[i],pool[i],sizeof(pcopy[i]));
        }
        players[k].rank.kicker=1;//checks highcard
        int  hcard1=CardStrength(players[k].hand[0][0]);
        int  hcard2=CardStrength(players[k].hand[1][0]);
        if(hcard1>hcard2) {
            strlcpy(players[k].hand[0],players[k].info.highcard,sizeof(players[k].hand[0]));
        }
        if(hcard2>hcard1) {
            strlcpy(players[k].hand[1],players[k].info.highcard,sizeof(players[k].hand[0]));
        }

        for(int i=0; i<7; i++) {//checking pair trips && quads
            if(pcopy[i][0]!='\0') {
                freq[cardstrength[i]]++;
                pcopy[i][0]='\0';
            }
        }
        for (int i = 0; i < 13; i++) {//checks pair trips twopair fullhouse and quad
            if (freq[i] == 2) players[k].rank.pair=1;
            if (freq[i] == 3) players[k].rank.trips=1;
            if (freq[i] == 4) players[k].rank.quads=1;
        }
        if(players[k].rank.pair==1||players[k].rank.trips==1) {
            for(int i=0; i<7; i++) {
                if(pcopy[i][0]!='\0') {
                    freqtwo[cardstrength[i]]++;
                    pcopy[i][0]='\0';
                }
            }
            for (int i = 0; i < 13; i++) {//checking two pair fullhouse
                if (freqtwo[i] == 2) players[k].rank.twopair=1;
            }
            if(players[k].rank.trips==1&&players[k].rank.pair==1) {
                players[k].rank.fullhouse=1;
            }
        }
        for(int i=0; i<7; i++) {
            poolint[i]=CardStrength(pool[i][1]);
        }
        for(int s=14; s!=1; s--) {
            for(int i=0; i<7; i++) {
                if(poolint[i]!=s) continue;
                for(int j=0; j<7; j++) {
                    if(empty[j]!=0) continue;
                    empty[j]=poolint[i];
                }
            }
        }

        for(int i=0; i<7; i++) {//checking straight
            if(empty[i]-empty[i+1]!=1&&straight_count!=5) {
                straight_count=0;
                empty[i]=0;
            }
            straight_count++;
            if(straight_count>5) {
                empty[i+1]=0;
            }
        }
        if(straight_count>=5) {
            players[k].rank.straight=1;
        }

        for (int i = 0; i < 7; i++) {//checking flush
            char s = pool[i][1];

            if (s == 'h') suit_count[0]++;
            else if (s == 'd') suit_count[1]++;
            else if (s == 'c') suit_count[2]++;
            else if (s == 's') suit_count[3]++;
        }
        for (int i = 0; i < 4; i++) {
            if (suit_count[i] <= 5) continue;
            players[k].rank.flush=true;
        }
        if(players[k].rank.flush==1&&players[k].rank.straight==1) {
            players[k].rank.straightflush=1;
        }
        if(players[k].rank.straightflush==1&&players[k].info.highcard[0]=='A') {
            players[k].rank.royalstraight=1;
        }
        Ranking(k);
    }
}

// GAME LOOP
void QueIncrement() {
//because active can be==4 it will rerandomize if put into que()
    int active=PlayersActive();
    char playerque[4][4]= {"UTG","BTN","SB","BB"};
    for(int i=0; i<active; i++) {
        if(players[i].state.active==0) {
            players[i].player_number=0;
        }
        players[i].player_number++;
        if(players[i].player_number>active) {
            players[i].player_number=1;
        }
    }
    for(int i=0; i<active; i++) {
        for(int j=0; j<4; j++) {
            if(players[i].state.active==0) continue;
            if(players[i].player_number!=j+1) continue;
            strlcpy(players[i].que,playerque[j],sizeof(players[i].que));
        }
    }
}

void DealHands() {
    for(int i = 0; i <4; i++) {
        if(players[i].state.active == false) continue;
        strlcpy(players[i].hand[0],deck[Pop()],sizeof(players[i].hand[0]));
        strlcpy(players[i].hand[1],deck[Pop()],sizeof(players[i].hand[1]));
    }
}

void PreBets() {
    int active=PlayersActive();
    bet.call=20;
    for(int i=0; i<active; i++) {
        if(strcmp(players[i].que,"SB")==0) {
            players[i].chips-=(players[i].chips<=SMALLBLIND) ? players[i].chips : SMALLBLIND;
            bet.pot+=SMALLBLIND;
        }
        if(strcmp(players[i].que,"BB")==0) {
            players[i].chips-=(players[i].chips<=BIGBLIND) ? players[i].chips : BIGBLIND;
            bet.pot+=BIGBLIND;
        }
    }

}
void ShareChips() {
    float comp;
    int loosechips=0;
    int active=PlayersActive();
    for(int i=0; i<4; i++) {
        if(players[i].lives==0&&players[i].chips!=0) {
            loosechips+=players[i].chips;
        }
    }
    loosechips+=bet.pot;
    comp = floor((float)loosechips / active);
    for(int i=0; i<active; i++) {
        if(players[i].chips > 0 && players[i].lives > 0) {
            players[i].chips+=(int)comp;
        }
    }
}

