                players[0].token=true;
            }
            if(confirm==2) {
                G_pot=players[0].chips+G_pot;
                players[0].chips=0;
                players[0].state.allin=true;
            }
            if(confirm==3) {
                PlayerMove();
            }
        }
    }
    if(options==3) {
        printf("Fold?\n1:Yes 2:No\n");
        confirm=Val_Auth(1,2);
        players[0].state.folded=(confirm==1) ? 1 : PlayerMove();
    }
}

