            confirm=Val_Auth(1,2);
            players[0].chips=(confirm==1) ? players[0].chips-betamount: PlayerMove();
            G_pot=(confirm==1) ? G_pot+betamount : Holder();
        }
        if(betamount==players[0].chips||options==2) {
            printf("Go All In\n1:Yes 2:No\n");
            confirm=Val_Auth(1,2);
            if(confirm==2) {
                PlayerMove();
            }
            printf("use token\n1:Yes 2:No 3: Back\n");
