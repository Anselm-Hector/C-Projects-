int PlayersActive() {
    int active=4;
    for(int i=0; i<4; i++) {
        if(players[i].chips==0||players[i].lives==0) {
            active--;
            players[i].state.out = true;
            players[i].state.active = false;
        }
    }
    if(active==1) {
        GameOverCheck();
    }
    return active;
}

void ShareChips() {
    float comp;
    int loosechips=0;
    int active=PlayersActive();
    for(int i=0; i<4; i++) {
        if(players[i].lives==0&&players[i].chips!=0) {
            loosechips=loosechips+players[i].chips;
        }
    }
    comp = floor((float)loosechips / active);

    for(int i=0; i<active; i++) {
        if(players[i].chips > 0 && players[i].lives > 0) {
            players[i].chips=(int)comp+players[i].chips;
        }
    }
}

