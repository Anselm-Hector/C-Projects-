void Deck() {
    char cardname[13]= {'A','2','3','4','5','6','7','8','9','T','J','Q','K'};
    char suite[4]= {'H','D','C','S'};
    top= -1;
    for(int i=0; i<4; i++) {
        for(int j=0; j<13; j++) {
            char card[3];
            card[0]=cardname[j];
            card[1]=suite[i];
            card[2]='\0';
            top++;
            strlcpy(deck[top],card,sizeof(deck[top]));
        }
    }
    for (int i = 51; i > 0; i--) {
        int j = rand() % (i + 1);
        char temp[3];
        strlcpy(temp, deck[i],sizeof(temp));
        strlcpy(deck[i], deck[j],sizeof(deck));
        strlcpy(deck[j], temp,sizeof(deck));
    }
}

