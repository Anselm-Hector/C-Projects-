            goto blindcheckgt;
        }
        if(players[i].info.highcard=='A'||'K'||'Q'||'J'||'T') {
            highcardb=10;
        }
        if(players[i].info.highcard=='9'||'8'||'7'||'6') {
            highcardb=5;
        }
        if(players[i].info.highcard=='5'||'4'||'3'||'2') {
            highcardb=0;
        }

        if(players[i].info.range==0) { //is a pair
            pairb=15;
        }
        if(players[i].info.range==1) {
            pairb=10;
        }
        if(players[i].info.range==2||3) {
            pairb=5;
        }
        if(players[i].info.range==4||5) {
            pairb=0;
        }
        suitedb=(players[i].info.suited==1) ? 10:0;

        bet=highcardb+pairb+suitedb;
        players[i].state.folded=(bet<20)? 1:0;
blindcheckgt:
        if((players[i].que=="BB"||"SB")&& bet>=20) {
            bet=("BB") ? 10:15;
        }
    }
}
