//AI LOGIC
void BetLogic(int a) {
    if(players[a].state.folded == 1 ||
            players[a].state.out == 1 ||
            players[a].state.active != 1 ||
            players[a].state.allin == 1) return;

    int highcardb;
    if(board.river!=1) Exceptions(a);
    highcardb=CardStrength(players[a].info.highcard[0]);
    if(board.preflop==1) {
        if(players[a].ranking==1 && bet.call>20) players[a].state.folded=1;
    }
    if ((players[a].ranking >= 1 && players[a].ranking <= 4) && bet.call==200 && board.river !=1) {//add a feature for a flag of a all in player
        players[a].state.folded=1;
    }//exceptions for folded state
    if (players[a].ranking >= 1 && players[a].ranking <= 10) { //update this is statement
        Bets(players[a].bets-bet.call,0,a);
    }//call condition
    if (players[a].ranking >= 8 && players[a].ranking <= 10 && board.river==1) Bets(0,1,a);
            Bets((players[a].ranking*3)+highcardb,0,a);//prevent continous betting
}

void Exceptions(int a) {
    int poolint[7]= {0},empty[7]= {0};
    int size=7,arrmover=0,rp[7]= {0},temp_count=0,lowest=5,count=0;
    for(int i=0; i<7; i++) {//converts pool into an int
        poolint[i]=CardStrength(pool[i][1]);
    }
    for(int s=14; s!=1; s--) {
        for(int i=0; i<7; i++) {
            if(poolint[i]!=s) continue;
            for(int j=0; j<7; j++) {
                if(empty[j]!=0) continue;
                empty[j]=poolint[i];
            }
        }
    }
    for (int i = 0; i < size; i++) {//checks potential range
        if(empty[i]-empty[i+1]==1) {//checking straight count
            count++;
            continue;
        }
        size=size+1;
        arrmover=size-i;
        for (int j=size; j!=arrmover; j--) {
            empty[j]=empty[j-1];
            rp[i]++;
        }
        empty[i]=empty[i]-1;
        temp_count=rp[i]+count;
        if(temp_count==5) {
            i++;
            temp_count=0;
        }
    }
    for(int i=0; i<7; i++) {
        if(rp[i]<lowest) {
            lowest=rp[i];
        }
    }
    int suit_count[4] = {0};
    for (int i = 0; i < 7; i++) {//checking flush
        char s = pool[i][1];
        if (s == 'h') suit_count[0]++;
        else if (s == 'd') suit_count[1]++;
        else if (s == 'c') suit_count[2]++;
        else if (s == 's') suit_count[3]++;
    }
    if((players[a].ranking==1||players[a].ranking==2)&&lowest<2) {
        players[a].rank.straight=true;
    }
    for (int i = 0; i < 4; i++) {
        if (suit_count[i] <= 4) continue;
        players[a].rank.flush=true;
    }
}

//LISTS
int Ranking(int i) {
    if(players[i].rank.kicker==1)
        return players[i].ranking=1;
    if(players[i].rank.pair==1)
        return players[i].ranking=2;
    if(players[i].rank.twopair==1)
        return players[i].ranking=3;
    if(players[i].rank.trips==1)
        return players[i].ranking=4;
    if(players[i].rank.straight==1)
        return players[i].ranking=5;
    if(players[i].rank.flush==1)
        return players[i].ranking=6;
    if(players[i].rank.fullhouse==1)
        return players[i].ranking=7;
    if(players[i].rank.quads==1)
        return players[i].ranking=8;
    if(players[i].rank.straightflush==1)
        return players[i].ranking=9;
    if(players[i].rank.royalstraight==1)
        return players[i].ranking=10;
}

int CardStrength(char c) {
    switch (c) {
    case '2':
        return 2;
    case '3':
        return 3;
    case '4':
        return 4;
    case '5':
        return 5;
    case '6':
        return 6;
    case '7':
        return 7;
    case '8':
        return 8;
    case '9':
        return 9;
    case 'T':
        return 10;
    case 'J':
        return 11;
    case 'Q':
        return 12;
    case 'K':
        return 13;
    case 'A':
        return 14;
    default:
        printf("Critical Error occured");
        return 0;
    }
}

void Bets(int a,int b, int c) {

    if (b==1) {
        players[c].state.allin=1;
        bet.pot+=players[c].chips;
        players[c].chips=0;
    }
    if((a+players[c].bets<bet.call)&&b==0) {
        printf("bet amount:%d",bet.call-players[c].bets);
        return;
    }
    if(a+players[c].bets>bet.call) { //basic raise condtion
        bet.call=a+players[c].bets;
    }
    bet.pot+=a;
    players[c].bets+=a;
    players[c].chips-=a;
}
